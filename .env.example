# Athena Environment Configuration
# Copy this file to .env and fill in your values

# =================================
# REQUIRED for full functionality
# =================================

# Google Gemini API key (for embeddings)
# Get yours at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# Supabase credentials (for vector storage)
# Get yours at: https://supabase.com/dashboard
# ⚠️ SECURITY: Use the ANON key, NOT the Service Role key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here

# =================================
# EMBEDDING PROVIDER CONFIGURATION
# =================================

# Choose your embedding provider: "gemini" or "ollama"
# - gemini: Cloud-based (requires GOOGLE_API_KEY)
# - ollama: Local (requires Ollama installed and running)
EMBEDDING_PROVIDER=gemini

# Ollama Configuration (only needed if EMBEDDING_PROVIDER=ollama)
# Install Ollama: https://ollama.com/download
# Start Ollama: ollama serve (or launch Ollama app)
# Pull model: ollama pull nomic-embed-text
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text
# Alternative models (must output 768 dimensions):
# OLLAMA_MODEL=mxbai-embed-large
# OLLAMA_MODEL=manutic/nomic-embed-code:7b-Q4_K_M

# =================================
# OPTIONAL features
# =================================

# Telegram Bot (for mobile access)
# Create via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=

# Anthropic Claude (for cross-model validation)
ANTHROPIC_API_KEY=
